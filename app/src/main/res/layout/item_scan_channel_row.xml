<?xml version="1.0" encoding="utf-8"?>
<!-- One row of the scan tab's tabulated channel view. Column widths/weights
     must match item_scan_channel_header.xml exactly so values line up under
     their headers. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#12161C"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp"
    android:gravity="center_vertical">

    <!-- Active/idle indicator -->
    <TextView
        android:id="@+id/tvColStatus"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:text="\u25CB"
        android:textColor="#666666"
        android:textSize="13sp"
        android:gravity="center"
        android:fontFamily="monospace"/>

    <!-- Frequency (MHz) -->
    <TextView
        android:id="@+id/tvColFreq"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:text="---.------"
        android:textColor="#00CCFF"
        android:textSize="12sp"
        android:fontFamily="monospace"/>

    <!-- Power (dBFS) -->
    <TextView
        android:id="@+id/tvColPower"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.3"
        android:text="---"
        android:textColor="#44FF88"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="end"/>

    <!-- Noise floor (dBFS) -->
    <TextView
        android:id="@+id/tvColFloor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.3"
        android:text="---"
        android:textColor="#77AACCFF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="end"/>

    <!-- Running hit count -->
    <TextView
        android:id="@+id/tvColHits"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0"
        android:textColor="#FFAA00"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="end"/>

    <!-- Age of last measurement -->
    <TextView
        android:id="@+id/tvColAge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:text="never"
        android:textColor="#88FFFFFF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="end"/>

</LinearLayout>
