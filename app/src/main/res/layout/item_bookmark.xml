<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1C2128"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginBottom="1dp"
    android:gravity="center_vertical">

    <!-- Color swatch (left side) -->
    <View
        android:id="@+id/viewColorSwatch"
        android:layout_width="4dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"/>

    <!-- Main content block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvBookmarkLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bookmark Label"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFAA00"
                android:contentDescription="Toggle favorite"/>
        </LinearLayout>

        <!-- Frequency -->
        <TextView
            android:id="@+id/tvBookmarkFreq"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100.000 MHz"
            android:textColor="#00CCFF"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"/>

        <!-- Mode tag + list name row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvBookmarkMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NFM"
                android:textColor="#FFAA00"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="#22FFAA00"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvBookmarkList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvBookmarkNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#55FFFFFF"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:maxWidth="180dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Tune button -->
    <Button
        android:id="@+id/btnTune"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:text="TUNE"
        android:textSize="11sp"
        android:backgroundTint="#00CCFF"
        android:textColor="#000000"
        android:layout_marginStart="8dp"/>

</LinearLayout>
