<?xml version="1.0" encoding="utf-8"?>
<!-- Tab 3 – RECORDING -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Recording" android:textColor="#FF4444" android:textSize="13sp"
        android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <Button android:id="@+id/btnRecordIq"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="Record IQ"
            android:backgroundTint="#333333" android:textColor="#FF4444"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnRecordAudio"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="Record Audio"
            android:backgroundTint="#333333" android:textColor="#FF4444"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:layout_marginVertical="12dp"/>

    <!-- Scheduled recording stop -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="120dp" android:layout_height="wrap_content"
            android:text="Auto-Stop" android:textColor="#AAFFFFFF" android:textSize="13sp"/>
        <Spinner android:id="@+id/spinnerRecordStop"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:backgroundTint="#FF4444"/>
    </LinearLayout>

    <!-- Squelch-gated recording -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Squelch-Gated Recording"
                android:textColor="#AAFFFFFF" android:textSize="13sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Only record when signal is above squelch threshold"
                android:textColor="#66FFFFFF" android:textSize="10sp"/>
        </LinearLayout>
        <Switch android:id="@+id/switchSquelchRecord"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:checked="false"/>
    </LinearLayout>

    <!-- Recordings list — placed at the bottom of the tab, below the recording
         controls above. Hidden entirely (visibility GONE) when there are no
         saved recordings yet; shown as soon as at least one exists. -->
    <LinearLayout android:id="@+id/containerRecordingsTabList"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:visibility="gone">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#33FFFFFF" android:layout_marginVertical="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Recordings" android:textColor="#FF4444" android:textSize="13sp"
            android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecordingsTab"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"/>

    </LinearLayout>

</LinearLayout>

</ScrollView>
