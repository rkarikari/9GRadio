<?xml version="1.0" encoding="utf-8"?>
<!-- Tab – Scan: embedded frequency scanner. Hidden by default; shown only
     when explicitly invoked (Scanner button / FAB), same pattern as the
     APRS/ACARS/DMR/YSF/D-STAR/Dig protocol tabs but triggered on demand
     instead of by DemodMode. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="12dp">

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Frequency Scanner"
        android:textColor="#00CCFF"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Start MHz"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScanTabStart"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberDecimal" android:text="136.0"
                android:textColor="#FFFFFF" android:fontFamily="monospace"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Stop MHz"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScanTabStop"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberDecimal" android:text="174.0"
                android:textColor="#FFFFFF" android:fontFamily="monospace"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Step Hz"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScanTabStep"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number" android:text="12500"
                android:textColor="#FFFFFF" android:fontFamily="monospace"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Squelch dB"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScanTabSquelch"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="numberSigned" android:text="-80"
                android:textColor="#FFFFFF" android:fontFamily="monospace"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Dwell ms"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etScanTabDwell"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number" android:text="200"
                android:textColor="#FFFFFF" android:fontFamily="monospace"/>
        </com.google.android.material.textfield.TextInputLayout>
        <Spinner android:id="@+id/spinnerScanTabMode"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:backgroundTint="#00CCFF"/>
    </LinearLayout>

    <!-- Scan direction switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="10dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Scan Direction: Down"
            android:textColor="#AAFFFFFF" android:textSize="12sp"/>
        <Switch android:id="@+id/switchScanTabDirection"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Adaptive squelch switch -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Adaptive Squelch (auto noise-floor tracking)"
            android:textColor="#AAFFFFFF" android:textSize="12sp"/>
        <Switch android:id="@+id/switchScanTabAdaptive"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:checked="false"/>
    </LinearLayout>

    <!-- Scan parameter memory slots -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="10dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Memory" android:textColor="#00CCFF" android:textSize="12sp"
            android:layout_marginEnd="8dp"/>
        <Spinner android:id="@+id/spinnerScanTabMemorySlot"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:backgroundTint="#00CCFF"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabMemSave"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Save" android:textSize="11sp"
            android:backgroundTint="#2C3440" android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabMemLoad"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Load" android:textSize="11sp"
            android:backgroundTint="#2C3440" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Control buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="12dp">
        <Button android:id="@+id/btnScanTabStartStop"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="Start Scan"
            android:textSize="12sp"
            android:backgroundTint="#00CC44" android:textColor="#000000"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabReset"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="Reset"
            android:textSize="12sp"
            android:backgroundTint="#2C3440" android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabPause"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:text="Pause"
            android:textSize="12sp"
            android:backgroundTint="#FFAA00" android:textColor="#000000"
            android:visibility="gone"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp">
        <Button android:id="@+id/btnScanTabSearch"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Search Mode"
            android:textSize="11sp"
            android:backgroundTint="#7A5CFF" android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabBusiest"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Busiest"
            android:textSize="11sp"
            android:backgroundTint="#2C3440" android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnScanTabClose"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Close"
            android:textSize="11sp"
            android:backgroundTint="#442222" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar android:id="@+id/progressScanTab"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:progressTint="#00CCFF" android:max="100"
        android:visibility="gone"/>

    <!-- Status -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp">
        <TextView android:id="@+id/tvScanTabCurrentFreq"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="---"
            android:textColor="#00CCFF" android:textSize="14sp"
            android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvScanTabSignal"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="--- dB" android:textColor="#44FF88"
            android:textSize="12sp" android:fontFamily="monospace"
            android:layout_marginEnd="12dp"/>
        <TextView android:id="@+id/tvScanTabHits"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Hits: 0" android:textColor="#FFAA00"
            android:textSize="12sp" android:fontFamily="monospace"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="4dp">
        <TextView android:id="@+id/tvScanTabNoiseFloor"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Floor: --- dB"
            android:textColor="#77AACCFF" android:textSize="11sp"
            android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvScanTabRate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="--- ch/s" android:textColor="#77AACCFF"
            android:textSize="11sp" android:fontFamily="monospace"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Active Frequencies (tap to tune, long-press to lock out):"
        android:textColor="#88FFFFFF" android:textSize="11sp"
        android:layout_marginTop="10dp" android:layout_marginBottom="4dp"/>

    <!-- Hit log (fixed height inside the drawer's own scroll view) -->
    <ListView
        android:id="@+id/listScanTabHits"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#0D1117"
        android:divider="#22FFFFFF"
        android:dividerHeight="0.5dp"
        android:nestedScrollingEnabled="true"/>

    <!-- Tabulated channel view: one row per configured channel, refreshed
         in place with its latest power/activity every time the scan
         revisits it (as opposed to the hit log above, which only ever
         appends). Modeled on SDRangel's Frequency Scanner channel table. -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Channel Table (live, tap to tune):"
        android:textColor="#88FFFFFF" android:textSize="11sp"
        android:layout_marginTop="10dp" android:layout_marginBottom="4dp"/>

    <ListView
        android:id="@+id/listScanTabChannelTable"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#0D1117"
        android:divider="#22FFFFFF"
        android:dividerHeight="0.5dp"
        android:nestedScrollingEnabled="true"/>

</LinearLayout>
