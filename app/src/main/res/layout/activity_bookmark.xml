<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <!-- Search + filter toolbar row -->
    <LinearLayout
        android:id="@+id/toolbarRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <!-- Search box -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Search bookmarks…"
                android:textColorHint="#66FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_search_box"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>

            <!-- Favorites filter toggle -->
            <ImageButton
                android:id="@+id/btnFilterFavorites"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#88FFFFFF"
                android:contentDescription="Show favorites only"/>

            <!-- Sort/options menu -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#88FFFFFF"
                android:contentDescription="More options"/>
        </LinearLayout>

        <!-- Horizontal list-selector (All / Uncategorized / each list) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/listChipsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:gravity="center_vertical"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Bookmark list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBookmarks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp"
        android:clipToPadding="false"
        android:paddingTop="112dp"
        android:paddingBottom="80dp"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="No bookmarks.\nTap ★ in the main screen to save a frequency."
        android:textColor="#55FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- FAB: add bookmark -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddBookmark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#00CCFF"
        android:contentDescription="Add bookmark"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
