        <item>4</item>
        <item>8</item>
        <item>16</item>
        <item>32</item>
    </string-array>

    <!-- Sample rates.  Two valid bands separated by a dead zone (~300–900 kS/s).
         Low-rate band (225–300 kS/s): reduced USB load, ideal for narrowband modes.
         Main band (900 kS/s – 2.4 MS/s): full-spectrum capability.
         Decimation factors shown are to the dynamic narrowIfRate. -->
    <string-array name="sample_rate_entries">
        <!-- Low-rate band (225 001–300 000 Hz) -->
        <item>240 kS/s  (÷5 → 48 kHz IF)</item>
        <item>242 kS/s  (÷5 → 48.4 kHz IF)</item>
        <item>250 kS/s  (÷5 → 50 kHz IF)</item>
        <item>256 kS/s  (÷5 → 51.2 kHz IF)</item>
        <item>264 kS/s  (÷5 → 52.8 kHz IF)</item>
        <item>272 kS/s  (÷5 → 54.4 kHz IF)</item>
        <item>286 kS/s  (÷5 → 57.2 kHz IF)</item>
        <item>288 kS/s  (÷6 → 48 kHz IF)</item>
        <item>300 kS/s  (÷6 → 50 kHz IF)</item>
        <!-- Main band: integer-divisor to narrowIfRate (48 kHz) -->
        <item>912 kS/s  (÷19)</item>
        <item>960 kS/s  (÷20)</item>
        <item>1.024 MS/s</item>
        <item>1.152 MS/s (÷24)</item>
        <item>1.200 MS/s (÷25)</item>
        <item>1.296 MS/s (÷27)</item>
        <item>1.440 MS/s (÷30)</item>
        <item>1.536 MS/s (÷32)</item>
        <item>1.680 MS/s (÷35)</item>
        <item>1.824 MS/s (÷38)</item>
        <item>1.920 MS/s (÷40)</item>
        <item>2.016 MS/s (÷42)</item>
        <item>2.048 MS/s</item>
        <item>2.160 MS/s (÷45)</item>
        <item>2.256 MS/s (÷47)</item>
        <item>2.400 MS/s (÷50)</item>
    </string-array>
